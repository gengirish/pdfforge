# ── PDFforge API Environment Variables ─────────────────────────────────────

# Auth — set API_KEY_REQUIRED=true to enforce Bearer token auth
API_KEY_REQUIRED=false
API_KEYS=pk_live_key1,pk_live_key2

# Rate limiting — max requests per API key (or IP) per hour
RATE_LIMIT=1000

# Job storage
JOB_DIR=/tmp/pdfforge_jobs
JOB_RETENTION_HOURS=2

# Workers (used by async job queue in Phase 2)
WORKER_THREADS=4

# Upload limits
MAX_CONTENT_LENGTH_MB=50

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Waitlist DB — SQLite path (or set WAITLIST_DATABASE_URL for Postgres)
WAITLIST_DB_PATH=./waitlist.db
# WAITLIST_DATABASE_URL=postgresql://user:pass@host:5432/dbname
WAITLIST_ADMIN_TOKEN=

# Lemon Squeezy
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_TEAM_VARIANT_ID=

# Anthropic (for /api/v1/agent/interpret in Phase 4)
# ANTHROPIC_API_KEY=sk-ant-...

# Webhook (Phase 2)
WEBHOOK_MAX_RETRIES=3
